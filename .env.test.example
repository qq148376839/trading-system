# 测试环境根级配置
# 复制为 .env.test 并填入实际值
# 启动: docker compose -p trading-test -f docker-compose.yml -f docker-compose.test.yml --env-file .env.test up -d --build

# 数据库（测试环境独立 DB）
POSTGRES_USER=trading_user
POSTGRES_PASSWORD=your_test_password_here
POSTGRES_DB=trading_db

# 前端 API 地址（测试环境端口 3003）
NEXT_PUBLIC_API_URL=http://192.168.31.18:3003
