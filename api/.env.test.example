# 测试环境 API 配置
# 复制为 api/.env.test 并填入实际值
# 此文件在 Docker 中挂载到 /app/api/.env

# 数据库连接（Docker 内部网络，postgres 是容器名）
DATABASE_URL=postgresql://trading_user:your_test_password_here@postgres:5432/trading_db

# LongPort 模拟盘 API（实际 key 存在数据库 system_config 表中）
# 以下仅作为 fallback，首次启动时需通过前端配置页面设置模拟盘 key
LONGPORT_APP_KEY=your_paper_trading_app_key
LONGPORT_APP_SECRET=your_paper_trading_app_secret
LONGPORT_ACCESS_TOKEN=your_paper_trading_access_token
LONGPORT_ENABLE_OVERNIGHT=true

# 服务器配置
PORT=3001
NODE_ENV=production
